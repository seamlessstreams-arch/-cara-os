# ── Required ────────────────────────────────────────────────────────────────
# Your Anthropic API key (https://console.anthropic.com). The agent runs on this.
ANTHROPIC_API_KEY=

# ── Cornerstone API the agent reads/writes ───────────────────────────────────
# Local dev:  http://localhost:3000/api/v1
# Deployed:   https://cornerstone-v2-fresh.vercel.app/api/v1
CORNERSTONE_API_BASE=http://localhost:3000/api/v1
# Optional bearer token, only if your API requires auth.
CORNERSTONE_API_TOKEN=
# Writes are OFF by default (read-only). Set to true to let the agent
# CREATE/UPDATE real care records. Leave false unless you really mean it.
CORNERSTONE_ALLOW_WRITES=false

# ── Optional ─────────────────────────────────────────────────────────────────
AGENT_MODEL=claude-sonnet-4-20250514
